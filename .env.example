DATABASE_URL=postgresql+asyncpg://logscope:logscope@localhost:5432/logscope
REDIS_URL=redis://localhost:6379/0

SESSION_COOKIE_SECURE=false
SESSION_TTL_SECONDS=2592000

LOGSCOPE_ADMIN_EMAIL=admin@logscope.local
LOGSCOPE_ADMIN_PASSWORD=changeme

LOG_LEVEL=INFO
LOG_FORMAT=json

# Anthropic（Match bar 用，無 key 時 Match 一律回空候選）
ANTHROPIC_API_KEY=
LLM_MATCH_MODEL=claude-haiku-4-5-20251001

# ClickHouse — backs Stats / Coverage. Started by `make dev-all` via stats profile;
# unset to disable Stats features without affecting the rest of the app.
CLICKHOUSE_URL=http://logscope:logscope@localhost:8123/logscope

# Copilot
LLM_COPILOT_MODEL=claude-haiku-4-5-20251001
LLM_COPILOT_MAX_HISTORY=20
LLM_COPILOT_MAX_LOG_LINES_IN_CONTEXT=20
LLM_COPILOT_MAX_VRL_CHARS_IN_CONTEXT=4000

# Copilot — D2 additions
LLM_COPILOT_VRL_MODEL=
LLM_COPILOT_MAX_LIBRARY_PRODUCTS_IN_CONTEXT=20
