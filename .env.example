DATABASE_URL=postgresql+asyncpg://logscope:logscope@localhost:5432/logscope
REDIS_URL=redis://localhost:6379/0

SESSION_COOKIE_SECURE=false
SESSION_TTL_SECONDS=2592000

LOGSCOPE_ADMIN_EMAIL=admin@logscope.local
LOGSCOPE_ADMIN_PASSWORD=changeme

LOG_LEVEL=INFO
LOG_FORMAT=json

# Anthropic（Match bar 用，無 key 時 Match 一律回空候選）
ANTHROPIC_API_KEY=
LLM_MATCH_MODEL=claude-haiku-4-5-20251001

# ClickHouse (optional — required for Stats / Coverage features)
# CLICKHOUSE_URL=http://logscope:logscope@localhost:8123/logscope
